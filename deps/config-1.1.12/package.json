{
  "name": "@lp/config",
  "version": "1.1.12",
  "description": "Configuration service for Leadpages",
  "main": "dist/config.js",
  "scripts": {
    "clean": "rm -rf dist",
    "test": "jest --coverage",
    "build": "yarn clean && yarn build:types && yarn build:js",
    "build:js": "babel --extensions '.ts' --ignore 'src/**/*.spec.ts','src/**/*.spec.tsx' src --out-dir dist",
    "build:types": "tsc --emitDeclarationOnly",
    "prepublish": "npm run build"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "author": "Foundation",
  "license": "ISC",
  "devDependencies": {
    "@babel/cli": "^7.8.4",
    "@babel/core": "^7.8.4",
    "@babel/preset-env": "^7.8.4",
    "@babel/preset-react": "^7.8.3",
    "@babel/preset-typescript": "^7.8.3",
    "@testing-library/react": "^9.4.0",
    "@types/jest": "^25.1.3",
    "@types/lodash": "^4.14.149",
    "jest": "^25.1.0",
    "react": "^16.12.0",
    "react-dom": "^16.12.0",
    "typescript": "^3.8.2"
  },
  "dependencies": {
    "lodash": "^4.17.15"
  }
}
