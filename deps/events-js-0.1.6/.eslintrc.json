{
  "extends": ["eslint:recommended", "plugin:prettier/recommended"],
  "plugins": ["prettier"],
  "env": {
    "browser": true,
    "es6": true,
    "jest": true,
    "node": true
  },
  "rules": {
    "comma-dangle": ["error", "always-multiline"],
    "prettier/prettier": ["error"]
  },
  "overrides": [
    {
      "files": ["*.js"]
    }
  ],
  "parser": "babel-eslint",
  "parserOptions": {
    "sourceType": "module"
  }
}
