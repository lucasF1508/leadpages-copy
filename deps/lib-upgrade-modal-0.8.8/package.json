{
  "name": "@lp/lib-upgrade-modal",
  "version": "0.8.8",
  "main": "build/index.js",
  "module": "build/esm/index.js",
  "repository": "https://github.com/leadpages/lib-upgrade-modal",
  "author": "LP Developers <developers@leadpages.net>",
  "license": "UNLICENSED",
  "prettier": {
    "trailingComma": "all",
    "singleQuote": true
  },
  "scripts": {
    "start": "start-storybook -p 9009 -s public",
    "build": "yarn build:non-esm && yarn build:esm",
    "build:non-esm": "NODE_ENV=production babel src -d build --ignore 'src/**/*.spec.js','src/**/*.stories.js'",
    "build:esm": "NODE_ENV=production ESM=true babel src -d build/esm --ignore 'src/**/*.spec.js','src/**/*.stories.js'",
    "dev": "nodemon -e js,jsx,json -w src --exec yarn run build",
    "test": "node scripts/test.js",
    "storybook": "start-storybook -p 9009 -s public",
    "build-storybook": "build-storybook -s public"
  },
  "eslintConfig": {
    "extends": "react-app",
    "plugins": [
      "react-hooks"
    ],
    "rules": {
      "react-hooks/rules-of-hooks": "error",
      "react-hooks/exhaustive-deps": "warn"
    }
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "peerDependencies": {
    "@lp/chevron": "file:../chevron-3.0.3",
    "@lp/config": "file:../config-1.1.12",
    "@lp/leads": "file:../leads-3.2.1",
    "@lp/ui": "file:../ui-1.4.31",
    "@material-ui/core": "^4.11.0",
    "@material-ui/icons": "^4.9.1",
    "@material-ui/lab": "^4.0.0-alpha.56",
    "clsx": "^1.1.0",
    "emotion": "^10.0.9",
    "prop-types": "^15.7.2",
    "react": "^16.8.6",
    "react-dom": "^16.8.6",
    "react-scripts": "2.1.8",
    "swiper": "^6.3.4"
  },
  "devDependencies": {
    "@babel/cli": "^7.4.4",
    "@babel/core": "^7.4.5",
    "@babel/plugin-transform-runtime": "^7.12.1",
    "@babel/preset-env": "^7.4.3",
    "@babel/preset-react": "^7.0.0",
    "@lp/chevron": "file:../chevron-3.0.3",
    "@lp/config": "file:../config-1.1.12",
    "@lp/leads": "file:../leads-3.2.1",
    "@lp/ui": "file:../ui-1.4.31",
    "@material-ui/core": "^4.11.0",
    "@material-ui/icons": "^4.9.1",
    "@material-ui/lab": "^4.0.0-alpha.56",
    "@storybook/addon-actions": "^5.3.19",
    "@storybook/addon-knobs": "^5.3.19",
    "@storybook/addon-links": "^5.3.19",
    "@storybook/addon-viewport": "^5.3.19",
    "@storybook/addons": "^5.3.19",
    "@storybook/react": "^5.3.19",
    "@svgr/webpack": "4.1.0",
    "@testing-library/dom": "^7.29.1",
    "@testing-library/jest-dom": "^5.11.8",
    "@testing-library/react": "^11.2.2",
    "@testing-library/user-event": "^12.6.0",
    "babel-core": "7.0.0-bridge.0",
    "babel-eslint": "9.x",
    "babel-jest": "26.3.0",
    "babel-loader": "^8.1.0",
    "babel-plugin-named-asset-import": "^0.3.1",
    "babel-preset-airbnb": "^3.2.1",
    "babel-preset-react-app": "^7.0.2",
    "bfj": "6.1.1",
    "case-sensitive-paths-webpack-plugin": "2.2.0",
    "dotenv": "6.0.0",
    "dotenv-expand": "4.2.0",
    "emotion": "^10.0.9",
    "enzyme": "^3.9.0",
    "enzyme-adapter-react-16": "^1.15.5",
    "eslint": "5.x",
    "eslint-config-prettier": "^6.11.0",
    "eslint-config-react-app": "^3.0.8",
    "eslint-loader": "^2.2.1",
    "eslint-plugin-flowtype": "2.x",
    "eslint-plugin-import": "2.x",
    "eslint-plugin-jsx-a11y": "6.x",
    "eslint-plugin-react": "7.x",
    "eslint-plugin-react-hooks": "2.x",
    "file-loader": "^6.1.0",
    "fs-extra": "9.0.1",
    "husky": "^1.3.1",
    "identity-obj-proxy": "3.0.0",
    "jest": "26.4.2",
    "jest-environment-enzyme": "^7.1.2",
    "jest-environment-jsdom": "^26.3.0",
    "jest-enzyme": "^7.1.2",
    "jest-watch-typeahead": "^0.6.0",
    "lint-staged": "^10.4.0",
    "nodemon": "^2.0.4",
    "pnp-webpack-plugin": "1.2.1",
    "prettier": "^1.16.4",
    "prop-types": "^15.7.2",
    "react": "^16.8.6",
    "react-app-polyfill": "^0.2.2",
    "react-dev-utils": "^8.0.0",
    "react-dom": "^16.8.6",
    "regenerator-runtime": "*",
    "resolve": "1.10.0",
    "swiper": "^6.3.4",
    "terser-webpack-plugin": "1.2.2",
    "url-loader": "1.1.2",
    "webpack": "4.28.3",
    "webpack-dev-server": "3.1.14",
    "webpack-manifest-plugin": "2.0.4"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts"
    ],
    "resolver": "jest-pnp-resolver",
    "setupFiles": [
      "react-app-polyfill/jsdom"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/config/jest/setup.js"
    ],
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.{js,jsx,ts,tsx}",
      "<rootDir>/src/**/?(*.)(spec|test).{js,jsx,ts,tsx}"
    ],
    "testEnvironment": "jsdom",
    "testURL": "http://localhost",
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "<rootDir>/node_modules/babel-jest",
      "^.+\\.css$": "<rootDir>/config/jest/cssTransform.js",
      "^(?!.*\\.(js|jsx|ts|tsx|css|json)$)": "<rootDir>/config/jest/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx|ts|tsx)$",
      "^.+\\.module\\.(css|sass|scss)$"
    ],
    "moduleNameMapper": {
      "^react-native$": "react-native-web",
      "^.+\\.module\\.(css|sass|scss)$": "identity-obj-proxy"
    },
    "moduleFileExtensions": [
      "web.js",
      "js",
      "web.ts",
      "ts",
      "web.tsx",
      "tsx",
      "json",
      "web.jsx",
      "jsx",
      "node"
    ],
    "watchPlugins": [
      "jest-watch-typeahead/filename",
      "jest-watch-typeahead/testname"
    ]
  }
}
