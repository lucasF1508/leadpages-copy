{
  "name": "@lp/ui",
  "version": "1.4.31",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf ./dist/* && yarn build:require && yarn build:esm",
    "build:require": "NODE_ENV=production rollup -c",
    "build:esm": "NODE_ENV=production ESM=true rollup -c",
    "build:analyze": "rm -f bundle-analysis.html && yarn build --config-analyze",
    "lint": "eslint ./src",
    "lint:staged": "eslint --fix --max-warnings=0",
    "start": "concurrently --names \"BUILD:REQUIRE,BUILD:ESM,STORYBOOK\" -c \"bgBlue.bold,bgMagenta.bold\" \"nodemon --watch src -e js,jsx,json,ts,tsx,md,mdx,markdown --exec yarn build:require\" \"nodemon --watch src -e js,jsx,json,ts,tsx,md,mdx,markdown --exec yarn build:esm\" \"yarn storybook\"",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook",
    "test": "node scripts/test.js",
    "test:coverage": "node scripts/test.js --coverage && open ./coverage/lcov-report/index.html",
    "test:ci": "CI=true node scripts/test.js"
  },
  "peerDependencies": {
    "@material-ui/core": "^4.11.0",
    "@material-ui/icons": "^4.9.1",
    "@material-ui/lab": "^4.0.0-alpha.54",
    "react": "^16.11.0",
    "react-dom": "^16.11.0"
  },
  "dependencies": {
    "@babel/runtime": "^7.10.4",
    "@lp/slugify": "file:../slugify-0.1.0.tgz",
    "clsx": "^1.0.4",
    "mui-phone-input-ssr": "^1.0.0",
    "prop-types": "^15.7.2",
    "react-color": "^2.18.1"
  },
  "devDependencies": {
    "@babel/core": "7.10.2",
    "@babel/plugin-proposal-class-properties": "^7.10.1",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.10.1",
    "@babel/plugin-proposal-object-rest-spread": "^7.10.1",
    "@babel/plugin-proposal-optional-chaining": "^7.10.1",
    "@babel/plugin-transform-react-constant-elements": "^7.10.1",
    "@babel/plugin-transform-runtime": "^7.10.1",
    "@babel/preset-env": "^7.10.2",
    "@babel/preset-react": "^7.10.1",
    "@emotion/core": "^10.0.22",
    "@material-ui/core": "^4.11.0",
    "@material-ui/icons": "^4.9.1",
    "@material-ui/lab": "^4.0.0-alpha.54",
    "@rollup/plugin-babel": "^5.0.3",
    "@rollup/plugin-commonjs": "^13.0.0",
    "@rollup/plugin-image": "^2.0.5",
    "@rollup/plugin-json": "^4.1.0",
    "@rollup/plugin-node-resolve": "^8.0.1",
    "@storybook/addon-actions": "^5.3.19",
    "@storybook/addon-links": "^5.3.19",
    "@storybook/addon-storysource": "^5.3.19",
    "@storybook/addons": "^5.3.19",
    "@storybook/preset-create-react-app": "^3.1.5",
    "@storybook/react": "^5.3.19",
    "@testing-library/dom": "^7.21.7",
    "@testing-library/jest-dom": "^5.10.1",
    "@testing-library/react": "^10.2.1",
    "@testing-library/user-event": "^12.8.3",
    "babel-jest": "^26.1.0",
    "babel-loader": "^8.1.0",
    "babel-plugin-optimize-clsx": "^2.6.0",
    "babel-plugin-transform-imports": "^2.0.0",
    "babel-plugin-transform-react-remove-prop-types": "^0.4.24",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "concurrently": "^4.1.0",
    "eslint-config-prettier": "^4.3.0",
    "husky": "^2.3.0",
    "jest": "^24.8.0",
    "jest-environment-jsdom-fourteen": "^1.0.1",
    "jest-watch-typeahead": "^0.6.0",
    "lint-staged": "^8.1.7",
    "nodemon": "^1.19.0",
    "prettier": "^1.17.1",
    "react": "^16.11.0",
    "react-dom": "^16.11.0",
    "react-number-format": "^4.3.1",
    "react-scripts": "^3.0.1",
    "react-test-renderer": "^16.8.6",
    "react-text-mask": "^5.4.3",
    "rollup": "^2.21.0",
    "rollup-plugin-filesize": "^9.0.1",
    "rollup-plugin-peer-deps-external": "^2.2.2",
    "rollup-plugin-progress": "^1.1.2",
    "rollup-plugin-visualizer": "^4.0.4"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js, jsx}": [
      "yarn run lint:staged",
      "git add"
    ],
    "*.{json,css,scss,md,yml,yaml}": [
      "prettier --write",
      "git add"
    ]
  },
  "browserslist": {
    "production": [
      "> 0.2%",
      "last 2 versions",
      "not dead"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "verbose": true,
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/**/*.stories.*"
    ],
    "moduleFileExtensions": [
      "web.js",
      "js",
      "json",
      "web.jsx",
      "jsx",
      "node"
    ],
    "roots": [
      "<rootDir>/src"
    ],
    "moduleNameMapper": {
      "\\.(jpg|ico|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/src/__mocks__/fileStub.js"
    },
    "setupFiles": [
      "<rootDir>/src/__mocks__/setup.js",
      "<rootDir>/src/__mocks__/localStorageMock.js"
    ],
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.{js,jsx}",
      "<rootDir>/src/**/*.{spec,test}.{js,jsx}"
    ],
    "transform": {
      "^.+\\.(js|jsx)$": "<rootDir>/node_modules/babel-jest"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx)$"
    ],
    "testEnvironment": "jest-environment-jsdom-fourteen",
    "watchPlugins": [
      "jest-watch-typeahead/filename",
      "jest-watch-typeahead/testname"
    ]
  }
}
