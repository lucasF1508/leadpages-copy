    "babel-preset-es2015": "^6.24.1",
    "babel-preset-es2016": "^6.24.1",
    "babel-preset-es2017": "^6.24.1",
    "babel-preset-react": "^6.24.1",
    "babel-preset-react-app": "^3.1.1",
    "colors": "^1.3.1",
    "commander": "^2.17.1",
    "core-js": "^2.5.7",
    "css-loader": "^0.28.11",
    "enzyme": "^3.9.0",
