    "rollup-plugin-re": "^1.0.7",
    "rollup-plugin-uglify": "^6.0.0",
    "style-loader": "^0.20.3",
    "stylelint": "^9.2.1",
    "stylelint-config-standard": "^18.2.0",
    "stylelint-order": "^0.8.1",
    "terser": "^3.8.1"
  },
  "dependencies": {
    "@lp/substring-matcher": "file:../substring-matcher-0.1.3.tgz",
    "animejs": "^2.2.0",
    "classnames": "^2.2.5",
    "emotion": "^9.2.12",
    "lodash": "^4.17.10",
    "prop-types": "^15.6.2",
    "react": "^16.8.6",
    "react-autocomplete": "^1.8.1",
    "react-color": "^2.14.1",
    "react-dom": "^16.8.6",
    "react-modal": "^3.5.1",
    "react-router-dom": "^4.2.2",
    "react-select": "^2.4.2",
    "react-transition-group": "1.x",
    "tinycolor2": "^1.4.1"
  },
  "peerDependencies": {
    "@lp/substring-matcher": "file:../substring-matcher-0.1.3.tgz",
    "animejs": "^2.2.0",
    "classnames": "^2.2.5",
    "emotion": "^9.2.12",
    "lodash": "^4.17.10",
    "prop-types": "^15.6.2",
    "react": "^16.8.1",
    "react-autocomplete": "^1.8.1",
    "react-color": "^2.14.1",
    "react-dom": "^16.8.1",
    "react-modal": "^3.5.1",
    "react-router-dom": "^4.2.2",
    "react-transition-group": "1.x",
    "tinycolor2": "^1.4.1"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,json,css}": [
      "prettier --single-quote --write",
      "git add"
    ]
  },
  "jest": {
    "moduleDirectories": [
      "node_modules"
    ],
    "moduleNameMapper": {
      "\\.(css|less)$": "identity-obj-proxy",
      "\\.(md)$": "<rootDir>/src/__mocks__/markdownStub.js"
    },
    "setupFiles": [
      "<rootDir>/src/__mocks__/setup.js",
      "<rootDir>/src/__mocks__/localStorageMock.js"
    ]
  }
