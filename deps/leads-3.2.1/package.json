{
  "name": "@lp/leads",
  "version": "3.2.1",
  "description": "The place to start for making a component library.",
  "main": "src/theme/Theme/index.js",
  "scripts": {
    "lint": "eslint src/",
    "lint:fix": "npm run lint -- --fix",
    "stylelint": "stylelint 'src/**/*.css'",
    "stylelint:fix": "stylelint 'src/**/*.css' --fix",
    "test": "jest",
    "test:watch": "jest  --watchAll",
    "storybook": "start-storybook -p 6006",
    "start": "yarn storybook",
    "precommit": "lint-staged",
    "build-storybook": "build-storybook",
    "add-component": "node ./scripts/addComponent.js addComponent",
    "link": "./scripts/link.sh",
    "build:link": "rm -rf ./dist/* && node ./scripts/build-dist.js",
    "watch": "yarn run link && yarn build:prod -w",
    "build": "NODE_ENV=development rollup --config rollup.config.js",
    "build:prod": "NODE_ENV=production rollup --silent --config rollup.config.js && NODE_ENV=development rollup --silent --config rollup.config.js",
    "publish:npm": "./scripts/publish-dist.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeadPages/leads.git"
  },
  "keywords": [
    "component",
    "library"
  ],
  "author": "Brian Bartholomew",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/LeadPages/leads/issues"
  },
  "homepage": "https://github.com/LeadPages/leads#readme",
  "devDependencies": {
    "@babel/core": "^7.1.2",
    "@babel/plugin-proposal-class-properties": "^7.1.0",
    "@babel/plugin-proposal-function-bind": "^7.0.0",
