    "lint-staged": "^7.0.1",
    "postcss": "^6.0.21",
    "postcss-cssnext": "^3.1.0",
    "postcss-import": "^11.1.0",
    "postcss-loader": "^2.1.3",
    "prettier": "^1.11.1",
    "react-component-component": "^1.2.1",
    "react-test-renderer": "^16.8.6",
