{
  "root": true,
  "project": {
    "basePath": "/studio"
  },
  "api": {
    "projectId": "1ux2e04i",
    "dataset": "production"
  },
  "plugins": [
    "@sanity/base",
    "@sanity/components",
    "@sanity/default-layout",
    "@sanity/default-login",
    "@sanity/desk-tool",
    "@sanity/production-preview",
    "@sanity/dashboard",
    "media",
    "@gearbox-built/studio/config",
    "gearbox-vercel-deploy",
    "gearbox-importer",
    "gearbox-doc-order-sort",
    "gearbox-autocomplete-address",
    "gearbox-multi-references",
    "gearbox-admin-message",
    "gearbox-live-preview",
    "gearbox-seo-pane",
    "gearbox-desk-tool",
    "gearbox-schema-tool",
    "gearbox-vimeo",
    "seo-pane",
    "table",
    "@sanity/orderable-document-list",
    "tags"
  ],
  "env": {
    "development": {
      "api": {
        "dataset": "development"
      },
      "plugins": ["@sanity/vision", "parts-list"]
