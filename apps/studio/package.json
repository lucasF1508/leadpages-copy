{
  "name": "studio",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "main": "package.json",
  "author": "Devin Edwards <devin@gearboxbuilt.com>",
  "license": "UNLICENSED",
  "scripts": {
    "start": "echo '\n\u001b[38;5;93mInjecting .env variables into studio:\u001b[38;5;219m'; while read line; do [[ $line == SANITY_* ]] && echo \"${line//\\\"/}\" && export \"${line//\\\"/}\"; done < $(for envFile in ../../.env.development ../../.env.local ../../.env; do [[ -f $envFile ]] && echo $envFile && break; done) && echo '\u001b[0m' && sanity start",
    "build:studio": "sanity build ../web/public/studio -y",
    "build": "yarn build:studio",
    "blast:node": "rm -rf node_modules"
  },
  "keywords": [
    "sanity"
  ],
  "dependencies": {
    "config": "*",
    "@sanity/base": "^2.25.4",
    "@sanity/components": "^2.2.6",
    "@sanity/core": "^2.25.0",
    "@sanity/dashboard": "^2.25.4",
    "@sanity/default-layout": "^2.25.4",
    "@sanity/default-login": "^2.24.1",
    "@sanity/desk-tool": "^2.25.4",
    "@sanity/production-preview": "^2.2.6",
    "@sanity/uuid": "^3.0.1",
    "@sanity/vision": "^2.25.4",
    "immutability-helper": "^3.1.1",
    "lodash": "^4.17.21",
    "prop-types": "^15.7",
    "react": "^17.0",
    "react-dnd": "^11.1.3",
    "react-dnd-html5-backend": "^14.0.0",
    "react-dom": "^17.0",
    "react-google-autocomplete": "^2.4.0",
    "react-icons": "^4.2.0",
    "react-polling": "^1.0.9",
    "react-select": "^5.1.0",
    "react-sortable-hoc": "^2.0.0",
    "sanity-plugin-media": "^1.3.1",
    "sanity-plugin-order-documents": "^0.0.22",
    "sanity-plugin-parts-list": "^1.0.2",
    "sanity-plugin-seo-pane": "^1.3.1",
    "sanity-plugin-table": "^2.3.0",
    "sanity-plugin-tabs": "^2.0.1",
    "slim-object-hash": "^0.1.2",
    "slugify": "^1.6.5",
    "styled-components": "^5.2.0",
    "uuid": "^8.3.2"
  },
