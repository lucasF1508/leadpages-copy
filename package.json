{
  "version": "3.6.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "yarn run check-node-version && turbo run lint",
    "start": "turbo run start --parallel",
    "serve": "turbo run serve",
    "dev": "yarn start",
    "format": "prettier --write \"**/*.{js,ts,tsx,md}\"",
    "docs:map": "yarn workspace migration run map",
    "docs:import": "yarn workspace migration run import",
    "docs:delete": "yarn workspace migration run delete",
    "blast:node": "turbo run blast:node",
    "blast:next": "turbo run blast:next",
    "blast:dist": "turbo run blast:dist",
    "blast:turbo": "rm -rf ./node_modules/.cache/turbo",
    "blast": "yarn blast:node && yarn blast:turbo && yarn blast:next && yarn blast:dist && rm -rf node_modules",
    "reset": "yarn blast && rm yarn.lock",
    "build:web": "yarn workspace web build",
    "analyze": "turbo run analyze",
    "icons": "yarn workspace icons build",
    "check-node-version": "node scripts/check-node-version.js"
  },
  "dependencies": {},
  "devDependencies": {
    "turbo": "^1.2.6"
  },
  "packageManager": "yarn@1.19.1"
}
