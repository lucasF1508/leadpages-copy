{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Sanity",
  "extends": "tsconfig/sanity.json",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@schema/*": [
        "./schema/*"
      ]
    },
    "types": [
      "vite/client"
    ]
  },
  "include": [
    "vite-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
  ],
  "exclude": [
    "node_modules"
  ]
}