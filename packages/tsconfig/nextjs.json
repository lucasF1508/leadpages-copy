{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "NextJS",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "es2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noImplicitAny": true,
    "jsx": "preserve",
    "strict": false,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "target": "es5"
  }
}
