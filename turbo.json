{
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "start": {
      "cache": false,
      "outputs": []
    },
    "client#build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "indices#build": {
      "cache": false,
      "dependsOn": ["client#build"],
      "outputs": []
    },
    "web#build": {
      "cache": false,
      "outputs": [".next/**", "dist/**"],
      "dependsOn": ["client#build", "indices#build", "studio#build"]
    },
    "studio#build": {
      "dependsOn": [],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "outputs": []
    },
    "serve": {
      "cache": false,
      "outputs": []
    },
    "blast:node": {
      "cache": false,
      "outputs": []
    },
    "blast:next": {
      "cache": false,
      "outputs": []
    },
    "blast:dist": {
      "cache": false,
      "outputs": []
    }
  },
  "globalDependencies": [".env"]
}
